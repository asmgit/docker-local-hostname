#!/usr/bin/env bash
# ldev-hosts — keep a managed block in /etc/hosts in sync with running docker
# containers whose hostname ends in the ldev domain (default ".ldev"), mapping
# each hostname to its container IP. Driven by docker events; updates on every
# container start/stop and flushes the macOS DNS cache when the set changes so
# changes are visible within ~1s.
#
# Container IPs (172.x) are made reachable from the macOS host by
# docker-mac-net-connect. This daemon only handles name -> IP resolution.
#
# Runs as a root launchd daemon. See com.ldev.hosts.plist.
export PATH=/usr/bin:/bin:/usr/sbin:/sbin:/usr/local/bin:/opt/homebrew/bin
export DOCKER_HOST="${DOCKER_HOST:-unix:///var/run/docker.sock}"
set -u

DOMAIN="${LDEV_DOMAIN:-.ldev}"
HOSTS=/etc/hosts
SOCK="${DOCKER_HOST#unix://}"
BEGIN="# BEGIN LDEV CONTAINERS"
END="# END LDEV CONTAINERS"
# url-encoded {"type":["container"],"event":["start","die","destroy"]}
FILTER='%7B%22type%22%3A%5B%22container%22%5D%2C%22event%22%3A%5B%22start%22%2C%22die%22%2C%22destroy%22%5D%7D'

PREV=""
backed_up=0

# Hostname and IP are read with separate inspects so whitespace/newlines in a
# container hostname can never bleed into the IP field. Both are validated
# before being written into the root-owned /etc/hosts.
collect() {
  local id host ip
  for id in $(docker ps -q 2>/dev/null); do
    host="$(docker inspect -f '{{.Config.Hostname}}' "$id" 2>/dev/null)"
    case "$host" in *"$DOMAIN") ;; *) continue ;; esac
    case "$host" in ''|*[!a-zA-Z0-9._-]*) continue ;; esac
    ip="$(docker inspect -f '{{range .NetworkSettings.Networks}}{{println .IPAddress}}{{end}}' "$id" 2>/dev/null \
          | grep -E '^[0-9]+(\.[0-9]+){3}$' | sort -V | head -1)"
    [ -n "$ip" ] && printf '%s %s\n' "$ip" "$host"
  done
}

rebuild() {
  # Never touch /etc/hosts when docker is unreachable: a transient outage would
  # otherwise wipe the whole block. This distinguishes "down" from "no containers".
  docker info >/dev/null 2>&1 || { echo "$(date '+%F %T') docker unreachable; leaving /etc/hosts untouched"; return; }

  local entries tmp
  entries="$(collect | sort -u)"

  [ "$backed_up" = 0 ] && { cp -f "$HOSTS" "${HOSTS}.ldev.bak" 2>/dev/null && backed_up=1; }

  tmp="$(mktemp "${HOSTS}.ldev.XXXXXX")" || return
  awk -v b="$BEGIN" -v e="$END" '$0==b{s=1;next} $0==e{s=0;next} !s{print}' "$HOSTS" >"$tmp"
  { echo "$BEGIN"; [ -n "$entries" ] && echo "$entries"; echo "$END"; } >>"$tmp"
  chmod 644 "$tmp"
  mv -f "$tmp" "$HOSTS"

  if [ "$entries" != "$PREV" ]; then
    PREV="$entries"
    dscacheutil -flushcache 2>/dev/null
    killall -HUP mDNSResponder 2>/dev/null
    echo "$(date '+%F %T') ${DOMAIN} hosts changed; flushed DNS"
    [ -n "$entries" ] && echo "$entries" | awk '{print "  " $0}' || echo "  (no ${DOMAIN} containers)"
  fi
}

rebuild
while true; do
  while IFS= read -r _; do rebuild; done < <(curl -sN --unix-socket "$SOCK" "http://localhost/events?filters=$FILTER")
  echo "$(date '+%F %T') docker events stream ended; reconnecting in 3s"
  sleep 3
done
